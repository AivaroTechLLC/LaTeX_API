# Copy this file to .env and fill in real values before starting the stack.
# Generate a secure API key: python -c "import secrets; print(secrets.token_hex(32))"

API_KEY=replace-with-a-32-byte-hex-secret

# Redis / Celery (default values match docker-compose service names)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Compilation limits
COMPILE_TIMEOUT=120
MAX_UPLOAD_SIZE_MB=20
MAX_MEMORY_MB=512
ALLOW_SHELL_ESCAPE=false

# API behaviour
RATE_LIMIT=20/minute
WEB_CONCURRENCY=2
DEBUG=false
ENABLE_PROMETHEUS=true

# Set explicitly — do NOT use * in production
CORS_ORIGINS=

# Comma-separated list of trusted reverse proxy IPs (leave blank for none)
TRUSTED_PROXY_IPS=
